#!/bin/sh

install() {
    # Check package
    if [ ! -d "$pkg_dir" ]; then
        echo "Error: Package directory '$pkg_dir' does not exist"
        exit 1
    fi

    # Check package in system
    if [ -d "$sys_pkg_dir" ]; then
        echo "Package '$pkg_name' has already been installed and will be uninstalled first"
        uninstall
    fi

    echo "Install: started"

    # Copy package to system
    if [ "$dry_run" = false ]; then
        mkdir -p "$sys_pkg_dir"
        cp -r "$pkg_dir"/* "$sys_pkg_dir"
    fi

    enter_pkg_dir "$pkg_dir"
    call_func_if_exists "pre_install"

    copy_files "$pkg_bin_dir" "$sys_bin_dir"
    copy_files "$pkg_lib_dir" "$sys_lib_dir"
    copy_files "$pkg_share_dir" "$sys_share_dir"
    copy_files "$pkg_init_dir" "$sys_init_dir"
    copy_files "$pkg_etc_dir" "$sys_etc_dir"

    call_func_if_exists "post_install"
    exit_pkg_dir

    echo "Install: finished"
}

uninstall() {
    # Check package in system
    if [ ! -d "$sys_pkg_dir" ]; then
        echo "Error: package '$pkg_name' has not been installed"
        exit 1
    fi

    echo "Uninstall: started"

    enter_pkg_dir "$sys_pkg_dir"
    call_func_if_exists "pre_uninstall"

    remove_files "$pkg_bin_dir" "$sys_bin_dir"
    remove_files "$pkg_lib_dir" "$sys_lib_dir"
    remove_files "$pkg_share_dir" "$sys_share_dir"
    remove_files "$pkg_init_dir" "$sys_init_dir"
    # Avoid removing files in sys_conf_dir and preserve relative administration efforts

    call_func_if_exists "post_uninstall"
    exit_pkg_dir

    # Delete package from system
    if [ "$dry_run" = false ]; then
        rm -rf "$sys_pkg_dir"
    fi

    echo "Uninstall: finished"
}

call_func_if_exists() {
    local func="$1"

    local exists=$(func_exists "$func")
    if [ $exists = true ]; then
        echo_and_run "$func"
    fi
}

func_exists() {
    local func="$1"

    local result=$(command -v "$func")
    if [ -z "$result" ]; then
        echo false
    else
        echo true
    fi
}

list_installed() {
    if [ -d "$sys_pkgs_dir" ]; then
        local packages=$(ls -1 "$sys_pkgs_dir")
        if [ ! -z "$packages" ]; then
            for pkg_dir in "$sys_pkgs_dir"/*; do
                local pkg_name=$(basename "$pkg_dir")
                enter_pkg_dir "$pkg_dir"
                echo "$pkg_name $VERSION"
                exit_pkg_dir
            done
        fi
    fi
}

exec="setup"

help() {
    echo "$exec $setup_version"
    usage
}

usage() {
    printf "Usage:\n"
    printf "\t$exec install package_dir [--dry-run]\n"
    printf "\t$exec uninstall package_name [--dry-run]\n"
    printf "\t$exec list-installed\n"
    printf "\t$exec version\n"
    printf "\t$exec help\n"
    printf "Arguments:\n"
    printf "\tpackage_dir\trelative or absolute path of the package\n"
    printf "\tpackage_name\tthe directory name of package_dir\n"
    printf "Options:\n"
    printf "\t--dry-run\tonly print operations without actually executing them\n"
}

parse_setup_args() {
    dry_run=false
    if [ "$#" -gt 0 ]; then
        if [ "$1" = "--dry-run" ]; then
            shift

            dry_run=true

            refuse_args "$#"
        else
            exit_with_usage
        fi
    fi
}

sys_root_dir="${SYS_ROOT_DIR}"
. "$sys_root_dir/etc/setup.conf"
. "$sys_root_dir/usr/local/lib/setup/common"
. "$sys_root_dir/usr/local/lib/setup/info"
sys_pkgs_dir="$sys_root_dir/usr/local/lib/setup/packages"

require_args "$#" 1
if [ "$1" = "install" ]; then
    shift

    require_args "$#" 1
    pkg_dir="$1"
    pkg_dir=$(realpath "$pkg_dir")
    pkg_name=$(basename "$pkg_dir")
    sys_pkg_dir="$sys_pkgs_dir/$pkg_name"
    shift

    parse_setup_args "$@"

    install
elif [ "$1" = "uninstall" ]; then
    shift

    require_args "$#" 1
    pkg_name="$1"
    sys_pkg_dir="$sys_pkgs_dir/$pkg_name"
    shift

    parse_setup_args "$@"

    uninstall
elif [ "$1" = "list-installed" ]; then
    shift

    refuse_args "$#"

    list_installed
elif [ "$1" = "version" ]; then
    shift

    refuse_args "$#"

    print_setup_version
elif [ "$1" = "help" ]; then
    shift

    refuse_args "$#"

    help
else
    exit_with_usage
fi
