#!/bin/sh

export_dev() {
    local script_bin_dir=$(basename "$script_dir")
    if [ "$script_bin_dir" != "$pkg_bin_dir" ]; then
        echo "Error: Projects compatible with Setup.sh should put the entrance scripts in a 'bin' dir"
        exit 1
    fi

    if [ "$script_dir" = "$sys_bin_dir" ]; then
        if [ ! -z "$pkg_name" ]; then
            pkg_base_dir="$sys_pkgs_dir/$pkg_name"
        fi
        DEV=false
    else
        pkg_base_dir=$(dirname "$script_dir")
        DEV=true
    fi
}

export_dirs() {
    BIN_DIR=$(get_dir "$pkg_bin_dir" "$sys_bin_dir")
    LIB_DIR=$(get_dir "$pkg_lib_dir" "$sys_lib_dir")
    SHARE_DIR=$(get_dir "$pkg_share_dir" "$sys_share_dir")
    INIT_DIR=$(get_dir "$pkg_init_dir" "$sys_init_dir")
    ETC_DIR=$(get_dir "$pkg_etc_dir" "$sys_etc_dir")
}

get_dir() {
    local pkg_dir="$1"
    local sys_dir="$2"
    if [ "$DEV" = true ]; then
        echo "$pkg_base_dir/$pkg_dir"
    else
        echo "$sys_dir"
    fi
}

export_info() {
    if [ ! -z "$pkg_base_dir" ]; then
        enter_pkg_dir "$pkg_base_dir"
        exit_dir
    fi
}

. "/etc/setup.conf"
. "/usr/lib/setup/common"

script=$(realpath "$0")
script_dir=$(dirname "$script")

export_dev
export_dirs
export_info
