#!/bin/sh

get_config() {
    while IFS='=' read key value; do
        if [ "$key" = "bin_dirs" ]; then
            dev_bin_dir="${value%:*}"
            sys_bin_dir="${value#*:}"
        elif [ "$key" = "lib_dirs" ]; then
            dev_lib_dir="${value%:*}"
            sys_lib_dir="${value#*:}"
        elif [ "$key" = "share_dirs" ]; then
            dev_share_dir="${value%:*}"
            sys_share_dir="${value#*:}"
        elif [ "$key" = "etc_dirs" ]; then
            dev_etc_dir="${value%:*}"
            sys_etc_dir="${value#*:}"
        fi
    done <"/etc/setup.conf"
}

export_dev() {
    local script_bin_dir=$(basename "$script_dir")
    if [ "$script_bin_dir" != "$dev_bin_dir" ]; then
        echo "Error: Projects compatible with Setup.sh should put the entrance scripts in a 'bin' dir"
        exit 1
    fi

    if [ "$script_dir" = "$sys_bin_dir" ]; then
        DEV=false
    else
        base_dir=$(dirname "$script_dir")
        DEV=true
    fi
}

export_dirs() {
    BIN_DIR=$(get_dir "$dev_bin_dir" "$sys_bin_dir")
    LIB_DIR=$(get_dir "$dev_lib_dir" "$sys_lib_dir")
    SHARE_DIR=$(get_dir "$dev_share_dir" "$sys_share_dir")
    ETC_DIR=$(get_dir "$dev_etc_dir" "$sys_etc_dir")
}

get_dir() {
    local dev_dir="$1"
    local sys_dir="$2"
    if [ "$DEV" = true ]; then
        echo "$base_dir/$dev_dir"
    else
        echo "$sys_dir"
    fi
}

script=$(realpath "$0")
script_dir=$(dirname "$script")

get_config
export_dev
export_dirs
