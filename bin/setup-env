#!/bin/sh


get_dir() {
    local sys_dir="$1"
    local dev_dir="$2"
    if [ "$dev" = true ]; then
        echo "$base_dir/$dev_dir"
    else
        echo "$sys_dir"
    fi
}


script="$0"
script=$(realpath "$script")
script_dir=$(dirname "$script")

SYS_BIN_DIR="/usr/bin"
DEV_BIN_DIR="bin"

dev_bin_dir=$(basename "$script_dir")
if [ "$dev_bin_dir" != "$DEV_BIN_DIR" ]; then
    echo "Error: Projects compatible with Setup.sh should put the entrance scripts in a 'bin' dir"
    exit 1
fi

if [ "$script_dir" = "$SYS_BIN_DIR" ]; then
    dev=false
else
    base_dir=$(dirname "$script_dir")
    dev=true
fi
export DEV="$dev"


bin_dir=$(get_dir "$SYS_BIN_DIR" "$DEV_BIN_DIR")
export BIN_DIR="$bin_dir"


SYS_LIB_DIR="/usr/lib"
DEV_LIB_DIR="lib"

lib_dir=$(get_dir "$SYS_LIB_DIR" "$DEV_LIB_DIR")
export LIB_DIR="$lib_dir"


SYS_SHARE_DIR="/usr/share"
DEV_SHARE_DIR="share"

share_dir=$(get_dir "$SYS_SHARE_DIR" "$DEV_SHARE_DIR")
export SHARE_DIR="$share_dir"


SYS_ETC_DIR="/etc"
DEV_ETC_DIR="etc"

etc_dir=$(get_dir "$SYS_ETC_DIR" "$DEV_ETC_DIR")
export ETC_DIR="$etc_dir"
