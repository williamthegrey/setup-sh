#!/bin/sh

enter_pkg_dir() {
    cd "$pkg_dir"
    source_pkg_file
}

enter_sys_pkg_dir() {
    cd "$sys_pkg_dir"
    source_pkg_file
}

source_pkg_file() {
    pkg_file="./package.sh"
    if [ -f "$pkg_file" ]; then
        . "$pkg_file"
    fi
}

exit_dir() {
    cd - >/dev/null
}

install() {
    # Check package
    if [ ! -d "$pkg_dir" ]; then
        echo "Error: Package directory '$pkg_dir' does not exist"
        exit 1
    fi

    # Check package in system
    if [ -d "$sys_pkg_dir" ]; then
        echo "Package '$pkg_name' has already been installed and will be uninstalled first"
        uninstall
    fi

    echo "Install: started"

    # Copy package to system
    if [ "$dry_run" = false ]; then
        mkdir -p "$sys_pkgs_dir"
        cp -r "$pkg_dir" "$sys_pkg_dir"
    fi

    enter_pkg_dir
    call_func_if_exists "pre_install"

    copy_files "$pkg_bin_dir" "$sys_bin_dir"
    copy_files "$pkg_lib_dir" "$sys_lib_dir"
    copy_files "$pkg_share_dir" "$sys_share_dir"
    copy_files "$pkg_init_dir" "$sys_init_dir"
    copy_files "$pkg_etc_dir" "$sys_etc_dir"

    call_func_if_exists "post_install"
    exit_dir

    echo "Install: finished"
}

copy_files() {
    local src_dir="$1"
    local dst_dir="$2"

    if [ -d "$src_dir" ]; then
        mkdir -p "$dst_dir"
        for_each_child_dir "$src_dir" "$dst_dir" create_dir
        if [ "$src_dir" = "$pkg_etc_dir" ]; then
            for_each_file "$src_dir" "$dst_dir" copy_etc_file
        else
            for_each_file "$src_dir" "$dst_dir" copy_file
            if [ "$src_dir" = "$pkg_bin_dir" ]; then
                for_each_file "$src_dir" "$dst_dir" make_executable
            elif [ "$src_dir" = "systemd" ]; then
                for_each_file "$src_dir" "$dst_dir" enable_systemd
            elif [ "$src_dir" = "sysvinit" ]; then
                for_each_file "$src_dir" "$dst_dir" make_executable
                for_each_file "$src_dir" "$dst_dir" enable_sysvinit
            fi
        fi
    fi
}

copy_file() {
    local src_file="$1"
    local dst_file="$2"

    echo_and_run cp "$src_file" "$dst_file"
}

copy_etc_file() {
    local src_file="$1"
    local dst_file="$2"

    # When two $src_file are almost the same except for one of them has a '.sample' extension
    # Only copy the one with the '.sample' extension
    if [ ! -f "$src_file.sample" ]; then
        # Remove the '.sample' extension when copying
        local final_dst_file="${dst_file%.sample}"
        # Avoid overwriting $final_dst_file from previous installation
        if [ ! -f "$final_dst_file" ]; then
            echo_and_run cp "$src_file" "$final_dst_file"
        fi
    fi
}

make_executable() {
    local src_file="$1"
    local dst_file="$2"

    echo_and_run chmod a+x "$dst_file"
}

enable_systemd() {
    local src_file="$1"
    local dst_file="$2"

    echo_and_run systemctl enable $(basename "$dst_file")
}

enable_sysvinit() {
    local src_file="$1"
    local dst_file="$2"

    echo_and_run "$dst_file" enable
}

create_dir() {
    local src_dir="$1"
    local dst_dir="$2"

    echo_and_run mkdir -p "$dst_dir"
}

uninstall() {
    # Check package in system
    if [ ! -d "$sys_pkg_dir" ]; then
        echo "Error: package '$pkg_name' has not been installed"
        exit 1
    fi

    echo "Uninstall: started"

    enter_sys_pkg_dir
    call_func_if_exists "pre_uninstall"

    remove_files "$pkg_bin_dir" "$sys_bin_dir"
    remove_files "$pkg_lib_dir" "$sys_lib_dir"
    remove_files "$pkg_share_dir" "$sys_share_dir"
    remove_files "$pkg_init_dir" "$sys_init_dir"
    # Avoid removing files in sys_conf_dir and preserve relative administration efforts

    call_func_if_exists "post_uninstall"
    exit_dir

    # Delete package from system
    if [ "$dry_run" = false ]; then
        rm -rf "$sys_pkg_dir"
    fi

    echo "Uninstall: finished"
}

remove_files() {
    local src_dir="$1"
    local dst_dir="$2"

    if [ -d "$src_dir" ]; then
        for_each_file "$src_dir" "$dst_dir" remove_file
        for_each_child_dir "$src_dir" "$dst_dir" remove_dir
    fi
}

remove_file() {
    local src_file="$1"
    local dst_file="$2"

    echo_and_run rm -f "$dst_file"
}

remove_dir() {
    local src_dir="$1"
    local dst_dir="$2"

    if [ -z $(ls -A "$dst_dir") ]; then
        echo_and_run rm -rf "$dst_dir"
    fi
}

echo_and_run() {
    local command="$@"

    echo "$command"
    if [ "$dry_run" = false ]; then
        $command
    fi
}

for_each_file() {
    local src_dir="$1"
    local dst_dir="$2"
    local func="$3"

    find "$src_dir" -type f | while read src_file; do
        local dst_file="$dst_dir/${src_file#*/}"
        "$func" "$src_file" "$dst_file"
    done
}

for_each_child_dir() {
    local src_dir="$1"
    local dst_dir="$2"
    local func="$3"

    find "$src_dir" -type d -path "$src_dir/*" | while read src_child_dir; do
        local dst_child_dir="$dst_dir/${src_child_dir#*/}"
        "$func" "$src_child_dir" "$dst_child_dir"
    done
}

call_func_if_exists() {
    local func="$1"

    local exists=$(func_exists "$func")
    if [ $exists = true ]; then
        echo_and_run "$func"
    fi
}

func_exists() {
    local func="$1"

    local result=$(command -v "$func")
    if [ -z "$result" ]; then
        echo false
    else
        echo true
    fi
}

list_installed() {
    ls -1 "$sys_pkgs_dir"
}

exit_with_usage() {
    usage
    exit 1
}

usage() {
    /bin/echo -e "Usage:"
    /bin/echo -e "\tsetup install package_dir [--dry-run]"
    /bin/echo -e "\tsetup uninstall package_name [--dry-run]"
    /bin/echo -e "\tsetup list-installed"
    /bin/echo -e "Arguments:"
    /bin/echo -e "\tpackage_dir\trelative or absolute path of the package"
    /bin/echo -e "\tpackage_name\tthe directory name of package_dir"
    /bin/echo -e "Options:"
    /bin/echo -e "\t--dry-run\tonly print operations without actually executing them"
}

parse_setup_args() {
    sys_pkg_dir="$sys_pkgs_dir/$pkg_name"

    if [ "$#" -lt 2 ]; then
        exit_with_usage
    fi
    dry_run=false
    if [ "$#" = 3 ]; then
        if [ "$3" = "--dry-run" ]; then
            dry_run=true
        else
            exit_with_usage
        fi
    fi
}

. "/usr/lib/setup-config"
sys_pkgs_dir="$sys_lib_dir/setup-packages"

if [ "$#" -lt 1 ] || [ "$#" -gt 3 ]; then
    exit_with_usage
fi

if [ "$1" = "install" ]; then
    pkg_dir="$2"
    pkg_dir=$(realpath "$pkg_dir")
    pkg_name=$(basename "$pkg_dir")
    parse_setup_args "$@"
    install
elif [ "$1" = "uninstall" ]; then
    pkg_name="$2"
    parse_setup_args "$@"
    uninstall
elif [ "$1" = "list-installed" ]; then
    if [ "$#" != 1 ]; then
        exit_with_usage
    fi
    list_installed
else
    exit_with_usage
fi
